PORT=3001
# Pegue em Mercado Pago > Suas integrações > Credenciais
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres
# Exemplo:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/alto_mar
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alto_mar

# JWT (troque em produção)
JWT_SECRET=dev-secret-change-me

# URL do front (Vite)
FRONTEND_URL=http://localhost:8080

# Opcional: domínios extra (domínio próprio, etc.), separados por vírgula
# EXTRA_CORS_ORIGINS=https://meusite.com,https://www.meusite.com

# Por defeito o CORS da API aceita qualquer origem (evita bloqueio de login Vercel ↔ Railway).
# Para restringir: CORS_STRICT=1 e preencha FRONTEND_URL + EXTRA_CORS_ORIGINS.
# CORS_STRICT=1


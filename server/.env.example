# --- Backend local (Windows) ---
# 1) Na raiz do repositório: npm run db:setup  (Docker: Postgres + schema + dados demo)
# 2) Copie este ficheiro para server/.env
# 3) npm.cmd run dev:all  (API :3001 + Vite :8080)
#
PORT=3001
# Pegue em Mercado Pago > Suas integrações > Credenciais
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres
# Exemplo:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/alto_mar
# Nuvem (Neon/Railway): use a connection string do painel; em geral inclui ?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alto_mar
#
# Opcional — erros intermitentes / "connection closed" / TLS:
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=20000
# PG_QUERY_RETRY_ATTEMPTS=3
# PG_KEEPALIVE_INITIAL_MS=10000
# Se o erro for SELF_SIGNED_CERT_IN_CHAIN ou certificado (só se souber o risco):
# DATABASE_SSL_REJECT_UNAUTHORIZED=0

# JWT (troque em produção)
JWT_SECRET=dev-secret-change-me

# URL do front (Vite)
FRONTEND_URL=http://localhost:8080

# Opcional: domínios extra (domínio próprio, etc.), separados por vírgula
# EXTRA_CORS_ORIGINS=https://meusite.com,https://www.meusite.com

# Por defeito o CORS da API aceita qualquer origem (evita bloqueio de login Vercel ↔ Railway).
# Para restringir: CORS_STRICT=1 e preencha FRONTEND_URL + EXTRA_CORS_ORIGINS.
# CORS_STRICT=1


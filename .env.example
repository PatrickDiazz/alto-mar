# Local: aponta para a API (ex.: 3001). O Vite faz proxy de /api para essa URL.
VITE_API_BASE_URL=http://127.0.0.1:3001
#
# No site em produção (Vercel), o app usa /api no mesmo domínio + rewrite em vercel.json
# para a Railway — evita CORS. Não precisa de VITE_API_BASE_URL no build da Vercel.
# Opcional: VITE_API_ALWAYS_DIRECT=1 para forçar URL absoluta em produção (exige CORS ok na API).

